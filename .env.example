# ══════════════════════════════════════════════════════
# Instituto Siqueira — Variáveis de ambiente
# Copie para .env e preencha. NUNCA versione o .env.
# ══════════════════════════════════════════════════════

# Notion (blog)
# Obtenha em: https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID do banco de dados do blog no Notion
# (veja NOTION_SETUP.md para como obter)
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Porta do servidor (opcional, default 3000)
PORT=3000
